CSS 
body { display: flex; justify-content: center; align-items: center; height: 100vh; background: black; color: lime; fontfamily: 'Courier New', monospace;
} 
.clock-container { textalign: center; 
} 
#clock { font-size: 
60px; letterspacing: 5px; 
} 
JavaScript 
function updateClock() { const now = new Date(); 
let hours = now.getHours(); let minutes = now.getMinutes(); let seconds = now.getSeconds(); 
// Add leading zero hours = hours < 10 ? "0" + hours : hours; minutes = minutes < 10 ? "0" + minutes : minutes; seconds = seconds < 10 ? "0" + seconds : seconds; const time = hours + ":" + minutes + ":" + seconds; 
document.getElementById("clock").textContent = time; 
} 
// Update every second setInterval(updateClock, 
1000); 
// Initial call 
updateClock();
